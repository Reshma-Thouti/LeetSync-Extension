{
  "manifest_version": 3,
  "name": "LeetSync",
  "version": "1.1",
  "permissions": [
    "storage",
    "scripting",
    "activeTab"
  ],
  "icons": {
    "16": "icon.png",
    "48": "icon.png",
    "128": "icon.png"
  },
  "host_permissions": [
    "https://leetcode.com/*",
    "https://api.github.com/*",
    "https://*.geeksforgeeks.org/*"
  ],
  "action": {
    "default_popup": "popup.html",
    "default_title": "LeetSync Settings"
  },
  "content_scripts": [
    {
      "matches": [
        "https://leetcode.com/problems/*"
      ],
      "js": ["content.js"]
    },
    {
      "matches": [
        "https://practice.geeksforgeeks.org/problems/*",
        "https://www.geeksforgeeks.org/problems/*"
      ],
      "js": ["content_gfg.js"]
    }
  ],
  "background": {
    "service_worker": "background.js"
  }
}